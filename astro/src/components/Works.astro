              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
            View Live Project
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        </div>

        <!-- Ask LLM Section - Commented out for now
        <div class="pt-4 border-t border-gray-200 space-y-4">
          <h3 class="text-xl font-semibold flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 8V4H8"></path>
              <rect width="16" height="12" x="4" y="8" rx="2"></rect>
              <path d="M2 14h2"></path>
              <path d="M20 14h2"></path>
              <path d="M15 13v2"></path>
              <path d="M9 13v2"></path>
            </svg>
            Ask AI about this project
          </h3>
          <div class="flex gap-2">
            <input
              type="text"
              id="llm-prompt"
              placeholder="Ask anything about this project..."
              class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-black transition-colors"
            />
            <button
              id="llm-submit"
              class="px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium rounded-lg hover:from-purple-700 hover:to-blue-700 transition-all flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="llm-btn-text">Ask</span>
              <svg
                id="llm-spinner"
                class="hidden animate-spin"
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
              </svg>
            </button>
          </div>
          <div
            id="llm-response"
            class="hidden p-4 bg-gray-50 rounded-lg border border-gray-200"
          >
            <p class="text-sm text-gray-500 mb-2">AI Response:</p>
            <p id="llm-response-text" class="text-gray-700 whitespace-pre-wrap">
            </p>
          </div>
          <p id="llm-error" class="hidden text-red-500 text-sm"></p>
        </div>
        -->
      </div>
    </div>
  </div>
</div>

<script>
  const ITEMS_PER_PAGE = 8;
  let currentPage = 1;
  let currentTab = "all";

  const tabButtons = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const portfolioItems =
    document.querySelectorAll<HTMLElement>(".portfolio-item");
  const prevPageBtn = document.getElementById("prev-page") as HTMLButtonElement;
  const nextPageBtn = document.getElementById("next-page") as HTMLButtonElement;
  const pageNumbersContainer = document.getElementById("page-numbers");

  function getFilteredItems(): HTMLElement[] {
    return Array.from(portfolioItems).filter((item) => {
      const categoryAttr = item.getAttribute("data-category");
      const categories: string[] = categoryAttr ? JSON.parse(categoryAttr) : [];
      return currentTab === "all" || categories.includes(currentTab);
    });
  }

  function getTotalPages(): number {
    const filteredItems = getFilteredItems();
    return Math.ceil(filteredItems.length / ITEMS_PER_PAGE);
  }

  function updatePagination() {
    const totalPages = getTotalPages();
    const filteredItems = getFilteredItems();

    // Hide all items first
    portfolioItems.forEach((item) => {
      item.style.display = "none";
    });

    // Show only items for current page
    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;
    
    filteredItems.slice(startIndex, endIndex).forEach((item) => {
      item.style.display = "flex";
    });

    // Update page numbers
    if (pageNumbersContainer) {
      pageNumbersContainer.innerHTML = "";
      for (let i = 1; i <= totalPages; i++) {
        const pageBtn = document.createElement("button");
        pageBtn.textContent = String(i);
        pageBtn.className = `w-10 h-10 rounded-full border-2 border-black font-medium transition-all duration-200 hover:bg-black hover:text-white ${
          i === currentPage ? "bg-black text-white" : "bg-white text-black"
        }`;
        pageBtn.addEventListener("click", () => {
          currentPage = i;
          updatePagination();
        });
        pageNumbersContainer.appendChild(pageBtn);
      }
    }

    // Update prev/next buttons
    if (prevPageBtn) {
      prevPageBtn.disabled = currentPage === 1;
    }
    if (nextPageBtn) {
      nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;
    }
  }

  // Tab click handler
  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const selectedTab = button.getAttribute("data-tab");
      currentTab = selectedTab || "all";
      currentPage = 1; // Reset to first page when changing tabs

      // Update active tab styling
      tabButtons.forEach((btn) => {
        btn.classList.remove("bg-black", "text-white");
        btn.classList.add("bg-white", "text-black");
      });
      button.classList.remove("bg-white", "text-black");
      button.classList.add("bg-black", "text-white");

      updatePagination();
    });
  });

  // Prev/Next button handlers
  prevPageBtn?.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  });

  nextPageBtn?.addEventListener("click", () => {
    if (currentPage < getTotalPages()) {
      currentPage++;
      updatePagination();
    }
  });

  // Initialize pagination
  updatePagination();

  // Modal functionality
  const modal = document.getElementById("portfolio-modal");
  const modalBackdrop = document.getElementById("modal-backdrop");
  const modalClose = document.getElementById("modal-close");
  const modalName = document.getElementById("modal-name");
  const modalCategory = document.getElementById("modal-category");
  const modalContent = document.getElementById("modal-content");
  const modalLink = document.getElementById("modal-link") as HTMLAnchorElement;

  /* LLM elements - Commented out for now
  const llmPrompt = document.getElementById("llm-prompt") as HTMLInputElement;
  const llmSubmit = document.getElementById("llm-submit") as HTMLButtonElement;
  const llmResponse = document.getElementById("llm-response");
  const llmResponseText = document.getElementById("llm-response-text");
  const llmError = document.getElementById("llm-error");
  const llmSpinner = document.getElementById("llm-spinner");
  const llmBtnText = document.getElementById("llm-btn-text");

  // TODO: Replace with your AI service endpoint
  const AI_API_ENDPOINT = "https://your-ai-service.com/api/chat";

  async function askAI(prompt: string) {
    const response = await fetch(AI_API_ENDPOINT, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ prompt }),
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Failed to get response");
    }

    // TODO: Adjust based on your API response structure
    return data.response;
  }

  llmSubmit?.addEventListener("click", async () => {
    const prompt = llmPrompt?.value.trim();
    if (!prompt) return;

    // Show loading state
    if (llmSpinner) llmSpinner.classList.remove("hidden");
    if (llmBtnText) llmBtnText.textContent = "Thinking...";
    if (llmSubmit) llmSubmit.disabled = true;
    if (llmError) llmError.classList.add("hidden");
    if (llmResponse) llmResponse.classList.add("hidden");

    try {
      const response = await askAI(prompt);
      if (llmResponseText) llmResponseText.textContent = response;
      if (llmResponse) llmResponse.classList.remove("hidden");
    } catch (error) {
      if (llmError) {
        const errorMsg = error instanceof Error ? error.message : "";
        if (errorMsg.toLowerCase().includes("failed to fetch") || errorMsg.toLowerCase().includes("network")) {
          llmError.textContent = "🎮 Sorry, we couldn't afford the GPUs to answer that. Have you seen NVIDIA prices lately? 💸";
        } else {
          llmError.textContent = errorMsg || "An error occurred";
        }
        llmError.classList.remove("hidden");
      }
    } finally {
      // Reset button state
      if (llmSpinner) llmSpinner.classList.add("hidden");
      if (llmBtnText) llmBtnText.textContent = "Ask";
      if (llmSubmit) llmSubmit.disabled = false;
    }
  });

  // Allow Enter key to submit
  llmPrompt?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      llmSubmit?.click();
    }
  });
  */

  function openModal(item: HTMLElement) {
    const name = item.getAttribute("data-name");
    const slug = item.getAttribute("data-slug");
    const cover = item.getAttribute("data-cover");
    const categoryAttr = item.getAttribute("data-category");
    const categories: string[] = categoryAttr ? JSON.parse(categoryAttr) : [];
    const link = item.getAttribute("data-link");

    /* Reset AI chat state - Commented out for now
    if (llmPrompt) llmPrompt.value = "";
    if (llmResponse) llmResponse.classList.add("hidden");
    if (llmError) llmError.classList.add("hidden");
    */

    if (modalName) modalName.textContent = name;
    if (modalCategory) modalCategory.textContent = categories.join(", ");
    if (modalLink) modalLink.href = link || "#";

    // Load rich content from hidden container
    if (modalContent && slug) {
      const contentSource = document.getElementById(`content-${slug}`);
      if (contentSource) {
        modalContent.innerHTML = contentSource.innerHTML;
      }
    }

    modal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  portfolioItems.forEach((item) => {
    item.addEventListener("click", (e) => {
      e.preventDefault();
      openModal(item);
    });
  });

  modalBackdrop?.addEventListener("click", closeModal);
  modalClose?.addEventListener("click", closeModal);

  // Close modal when clicking outside the modal content
  const modalOverlay = document.getElementById("modal-overlay");
  const modalContentWrapper = document.getElementById("modal-content-wrapper");
  
  modalOverlay?.addEventListener("click", (e) => {
    // Only close if clicking directly on the overlay, not on modal content
    if (e.target === modalOverlay) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
