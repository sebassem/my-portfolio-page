---
import svgPinkStar from "../assets/pink-star.svg";
import svgHl from "../assets/hl.svg";
---

<section class="px-3" id="hire">
  <div
    class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] relative p-10"
  >
    <h1 class="text-3xl">
      Ask My AI Assistant
    </h1>
    <p class="text-lg max-w-lg mx-auto">
      Have a job description or an interesting project ? Would you like to quickly understand if I would be a good fit and how I can bring impact?
      Ask my AI assistant!
    </p>
    <div class="flex flex-col gap-4 w-full max-w-lg mx-auto">
      <div class="relative">
        <textarea
          id="ai-question"
          class="w-full p-3 pb-8 border-2 border-black rounded-lg resize-none focus:outline-none focus:ring-2 focus:ring-pink-400"
          rows="3"
          maxlength="4000"
          placeholder="Type your job description here..."></textarea>
        <span id="char-count" class="absolute bottom-2 right-3 text-sm text-gray-500">0/4000</span>
      </div>
      <div class="flex justify-center">
        <div class="relative group">
          <button
            id="ask-ai-btn"
            disabled
            class="bg-[var(--blue)] text-black text-md font-medium flex items-center h-12 px-6 border-3 rounded-full cursor-pointer hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Ask AI
          </button>
          <img
            src={svgHl.src}
            width="30"
            class="absolute -right-7 -bottom-3 transition-all duration-200 group-hover:-bottom-4"
          />
        </div>
      </div>
    </div>
    <img
      src={svgPinkStar.src}
      alt="svg"
      width="80"
      class="absolute -top-10 right-20"
    />
  </div>
</section>

<!-- AI Response Modal -->
<div id="ai-modal" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  
  <!-- Modal Content -->
  <div class="absolute inset-0 flex items-center justify-center p-4" id="ai-modal-backdrop">
    <div class="relative bg-white max-w-4xl w-full max-h-[80vh] overflow-y-auto rounded-lg shadow-2xl" id="ai-modal-content">
      <!-- Close Button -->
      <button
        id="ai-modal-close"
        class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center bg-black text-white rounded-full hover:bg-gray-800 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      
      <!-- Modal Body -->
      <div class="p-8">
        <h3 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8"></path>
            <rect width="16" height="12" x="4" y="8" rx="2"></rect>
            <path d="M2 14h2"></path>
            <path d="M20 14h2"></path>
            <path d="M15 13v2"></path>
            <path d="M9 13v2"></path>
          </svg>
          AI Summary
        </h3>
        <div id="ai-response-text" class="prose prose-gray max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-strong:text-gray-900 prose-ul:text-gray-700 prose-ol:text-gray-700 prose-li:marker:text-gray-500">
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { askAI, warmupBackend } from "../services/aiService";
  import { marked } from "marked";

  const askAiBtn = document.getElementById("ask-ai-btn");
  const aiQuestion = document.getElementById(
    "ai-question"
  ) as HTMLTextAreaElement;
  const aiModal = document.getElementById("ai-modal");
  const aiModalBackdrop = document.getElementById("ai-modal-backdrop");
  const aiModalClose = document.getElementById("ai-modal-close");
  const aiResponseText = document.getElementById("ai-response-text");

  // Configure marked for safe rendering
  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  // Modal functions
  function openModal(text: string) {
    if (aiResponseText) {
      // Parse markdown and render as HTML
      aiResponseText.innerHTML = marked.parse(text) as string;
    }
    aiModal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  // Update modal content with streaming text
  function updateModal(text: string) {
    if (aiResponseText) {
      aiResponseText.innerHTML = marked.parse(text) as string;
    }
  }

  function closeModal() {
    aiModal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  // Modal event listeners
  aiModalBackdrop?.addEventListener("click", (e) => {
    // Only close if clicking directly on the backdrop, not the modal content
    if (e.target === aiModalBackdrop) {
      closeModal();
    }
  });
  aiModalClose?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // Warm up container on page load (fire and forget)
  warmupBackend();

  const charCount = document.getElementById("char-count");

  // Enable/disable button based on textbox content
  aiQuestion?.addEventListener("input", () => {
    const hasText = aiQuestion.value.trim().length > 0;
    if (hasText) {
      askAiBtn?.removeAttribute("disabled");
    } else {
      askAiBtn?.setAttribute("disabled", "true");
    }
    // Update character count
    if (charCount) {
      charCount.textContent = `${aiQuestion.value.length}/4000`;
    }
  });

  askAiBtn?.addEventListener("click", async () => {
    const question = aiQuestion?.value?.trim();

    if (!question) {
      alert("Please enter a question");
      return;
    }

    // Disable button and show loading state
    askAiBtn.textContent = "Asking...";
    askAiBtn.setAttribute("disabled", "true");

    try {
      let fullResponse = '';
      let modalOpened = false;
      
      // Stream callback - updates the modal in real-time
      const onChunk = (chunk: string, done: boolean, error?: string) => {
        if (error) {
          openModal(`Error: ${error}`);
          return;
        }
        
        fullResponse += chunk;
        
        // Open modal on first chunk
        if (!modalOpened && fullResponse.length > 0) {
          aiModal?.classList.remove("hidden");
          document.body.style.overflow = "hidden";
          modalOpened = true;
        }
        
        // Update modal content with streaming text
        updateModal(fullResponse);
      };
      
      const data = await askAI(question, onChunk);
      
      // Final update with complete response (in case no streaming occurred)
      if (!modalOpened) {
        const responseText = data.answer || data.message || "No response received";
        openModal(responseText);
      }
    } catch (error) {
      console.error("Error:", error);
      openModal("An error occurred. Please try again.");
    } finally {
      // Reset button state
      askAiBtn.textContent = "Ask AI";
      askAiBtn.removeAttribute("disabled");
    }
  });
</script>
