---
interface TimelineItem {
  year: string;
  title: string;
  company: string;
  logo?: string;
  description: string;
  highlights?: string[];
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;

import svgUnderline from "../assets/underline.svg";
---

<section class="py-25 space-y-10 px-5" id="career">
  <div class="max-w-md mx-auto relative">
    <h1 class="text-4xl font-medium text-center">Career Journey</h1>
    <img
      src={svgUnderline.src}
      alt="underline"
      width="140"
      class="absolute left-50 -bottom-1"
    />
  </div>

  <div class="max-w-5xl mx-auto">
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-black"></div>

      <!-- Timeline items -->
      {items.map((item, index) => (
        <div class={`relative flex flex-col md:flex-row gap-4 md:gap-8 mb-12 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
          <!-- Year badge -->
          <div class={`absolute left-0 md:left-1/2 md:-translate-x-1/2 w-8 h-8 bg-[var(--pink)] border-3 border-black rounded-full flex items-center justify-center z-10`}>
            <div class="w-3 h-3 bg-black rounded-full"></div>
          </div>

          <!-- Content card -->
          <div class={`ml-12 md:ml-0 md:w-[calc(50%-1rem)] ${index % 2 === 0 ? 'md:mr-auto md:pr-4' : 'md:ml-auto md:pl-4'}`}>
            <div class="bg-white border-3 border-black rounded-lg p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] transition-shadow">
              <div class="flex items-start justify-between gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-[var(--blue)] text-black text-sm font-bold rounded-full border-2 border-black">
                  {item.year}
                </span>
                {item.logo && (
                  <img 
                    src={item.logo} 
                    alt={`${item.company} logo`} 
                    class="w-8 h-8 object-contain"
                  />
                )}
              </div>
              <h3 class="text-xl font-bold mb-1">{item.title}</h3>
              <p class="text-gray-600 font-medium mb-3">{item.company}</p>
              <p class="text-gray-700 mb-3">{item.description}</p>
              {item.highlights && item.highlights.length > 0 && (
                <ul class="space-y-1">
                  {item.highlights.map((highlight) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                      <span class="text-[var(--pink)] mt-1">●</span>
                      {highlight}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ensure timeline line doesn't overflow */
  section {
    overflow: hidden;
  }
</style>
