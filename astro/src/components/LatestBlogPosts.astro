---
import svgUnderline from "../assets/underline.svg";
import { blogPosts } from "../data/blogPosts";
---

<section class="py-20 px-5" id="blog">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-md mx-auto relative mb-12">
      <h1 class="text-4xl font-medium text-center">Featured Blog Posts</h1>
      <img
        src={svgUnderline.src}
        alt="underline"
        width="140"
        class="absolute left-50 -bottom-1"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {blogPosts.map((post) => (
        <a
          href={post.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-white border-3 border-black rounded-lg overflow-hidden shadow-[4px_4px_0px_rgba(0,0,0,0.3)] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] hover:-translate-y-1 transition-all duration-200"
        >
          <div class="aspect-video overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4">
            <h3 class="font-medium text-lg leading-tight group-hover:text-[var(--blue)] transition-colors">
              {post.title}
            </h3>
            <p class="text-sm text-gray-500 mt-2">
              {new Date(post.date).toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric' 
              })}
            </p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://blog.seifbassem.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-black text-white px-6 py-3 rounded-full font-medium hover:bg-gray-800 transition-colors"
      >
        View All Posts
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
