{
  "routes": [
    {
      "route": "/blog/posts/*",
      "redirect": "https://blog.seifbassem.com/posts/:splat",
      "statusCode": 301
    },
    {
      "route": "/blog/*",
      "redirect": "https://blog.seifbassem.com/:splat",
      "statusCode": 301
    },
    {
      "route": "/*",
      "redirect": "https://portfolio.seifbassem.com",
      "statusCode": 302
    }
  ]
}
